{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 10,
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "permissions": {
    "allow": [
      "Bash(cargo build)",
      "Bash(cargo clippy)",
      "Bash(cargo test)",
      "Bash(gh issue create)",
      "Bash(gh issue list)",
      "Bash(gh issue view *)",
      "Bash(gh label list)",
      "Bash(gh pr checks *)",
      "Bash(gh pr list)",
      "Bash(gh run list)",
      "Bash(gh run view *)",
      "Bash(git checkout *)",
      "Bash(git fetch)",
      "Bash(git pull)",
      "Bash(git rebase)",
      "Bash(git stash)"
    ],
    "deny": [
      "Bash(sudo *)"
    ]
  }
}
